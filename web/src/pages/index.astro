---
import '../styles/theme.css';

const gridIcon =
  '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>';
const catalogIcon =
  '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>';
const refreshIcon =
  '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/></svg>';
const plusIcon =
  '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>';
const userIcon =
  '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>';
const lockIcon =
  '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>';
const shieldIcon =
  '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>';
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/static/dploy.svg" />
    <meta name="description" content="Dploy — launch ephemeral Kubernetes environments on demand." />
    <title>Dploy</title>
    <script is:inline>
      const saved = localStorage.getItem('dploy-theme');
      document.documentElement.dataset.theme = saved === 'light' ? 'light' : 'dark';
    </script>
  </head>
  <body>
    <header class="navbar">
      <div class="nav-inner">
        <a class="brand" data-link href="/">
          <img src="/static/dploy.svg" alt="" />
          <span>Dploy</span>
        </a>
        <nav class="nav-links">
          <a id="nav-instances" class="nav-link" data-link href="/"><Fragment set:html={gridIcon} /> My Instances</a>
          <a id="nav-catalog" class="nav-link" data-link href="/catalog"><Fragment set:html={catalogIcon} /> Catalog</a>
          <a id="nav-manager" class="nav-link" data-link href="/manager" hidden><Fragment set:html={shieldIcon} /> Manager</a>
        </nav>
        <div class="nav-actions">
          <button class="btn-icon" id="btn-theme" type="button" title="Toggle theme" aria-label="Toggle theme"></button>
          <span class="user-chip" id="nav-user" hidden><Fragment set:html={userIcon} /><span class="username"></span></span>
          <button class="btn btn-ghost" id="btn-logout" type="button" hidden>Logout</button>
          <button class="btn btn-primary" id="nav-login" type="button" hidden>Login with SSO</button>
        </div>
      </div>
    </header>

    <main>
      <!-- Login -->
      <section id="view-login" hidden>
        <div class="login">
          <div class="login-card">
            <div class="brand"><img src="/static/dploy.svg" alt="" /><span>Dploy</span></div>
            <div class="icon"><Fragment set:html={lockIcon} /></div>
            <h2>Authentication required</h2>
            <p>Sign in with your identity provider to manage instances.</p>
            <button class="btn btn-primary" id="login-btn" type="button" style="width:100%">Login with SSO</button>
          </div>
        </div>
      </section>

      <!-- My Instances -->
      <section id="view-home" hidden>
        <div class="hero">
          <h1>My Instances</h1>
          <p>Manage your running development instances</p>
        </div>
        <div class="container">
          <div class="section">
            <div class="section-head">
              <div>
                <h2>Active Instances</h2>
                <p>Your running development instances</p>
              </div>
              <div class="head-actions">
                <span class="counter" id="env-counter"></span>
                <button class="btn-icon" id="btn-refresh" type="button" title="Refresh"><Fragment set:html={refreshIcon} /></button>
                <a id="btn-new-instance" class="btn btn-primary" data-link href="/catalog"><Fragment set:html={plusIcon} /> New Instance</a>
              </div>
            </div>
            <div class="env-list" id="env-list"></div>
            <!-- Shown when INSTANCES_LIST_ENABLED=false: nothing to list, only direct /run/:env links work. -->
            <div class="state" id="env-list-disabled" hidden>
              This deployment doesn't expose an instance list. Launch an environment via a direct <code>/run/&lt;name&gt;</code> link.
            </div>
          </div>
        </div>
      </section>

      <!-- Catalog -->
      <section id="view-catalog" hidden>
        <div class="hero">
          <h1>Instance Catalog</h1>
          <p>Choose an instance template to deploy</p>
        </div>
        <div class="container">
          <div class="section">
            <div class="catalog-layout">
              <nav class="toc" id="catalog-toc"></nav>
              <div class="catalog-main" id="catalog-main"></div>
            </div>
          </div>
        </div>
      </section>

      <!-- Manager (admin) -->
      <section id="view-manager" hidden>
        <div class="hero">
          <h1>Manager</h1>
          <p>Cluster-wide admin view of every running instance and every template.</p>
        </div>
        <div class="container">
          <div class="section">
            <div class="section-head">
              <div class="tabs" role="tablist">
                <button class="tab active" data-tab="instances" type="button" role="tab" aria-selected="true">Instances</button>
                <button class="tab" data-tab="templates" type="button" role="tab" aria-selected="false">Templates</button>
              </div>
              <div class="head-actions">
                <span class="counter" id="manager-counter"></span>
                <button class="btn-icon" id="btn-manager-refresh" type="button" title="Refresh"><Fragment set:html={refreshIcon} /></button>
              </div>
            </div>
            <div id="manager-instances-pane"><div class="env-list" id="manager-list"></div></div>
            <div id="manager-templates-pane" hidden><div class="env-list" id="manager-templates-list"></div></div>
          </div>
        </div>
      </section>

      <!-- Run -->
      <section id="view-run" hidden>
        <div class="run">
          <div class="run-card">
            <div class="brand">
              <img src="/static/dploy.svg" alt="" />
              <span>Dploy</span>
            </div>
            <div class="run-env">
              <div class="label">Instance</div>
              <div class="name" id="run-env-name"></div>
            </div>
            <div id="run-content"></div>
          </div>
        </div>
      </section>
    </main>

    <div class="toasts" id="toasts"></div>

    <script>
      import '../scripts/main.ts';
    </script>
  </body>
</html>
